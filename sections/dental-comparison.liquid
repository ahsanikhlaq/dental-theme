            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
        </tr>
        <tr>
          <td>Bulk Discounts</td>
          <td class="dental-comparison__highlight">
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
        </tr>
      </tbody>
    </table>

    <!-- Price Comparison Footer -->
    <div class="dental-comparison__prices">
      <div class="dental-comparison__price-item dental-comparison__price-item--origin">
        <span class="dental-comparison__price-label">Dental Origin</span>
        <span class="dental-comparison__price">$34/unit</span>
      </div>
      <div class="dental-comparison__price-item dental-comparison__price-item--other">
        <span class="dental-comparison__price-label">Opalescence Go</span>
        <span class="dental-comparison__price">$50/unit</span>
      </div>
      <div class="dental-comparison__price-item dental-comparison__price-item--other">
        <span class="dental-comparison__price-label">Kor Night</span>
        <span class="dental-comparison__price">$62/unit</span>
      </div>
      <div class="dental-comparison__price-item dental-comparison__price-item--other">
        <span class="dental-comparison__price-label">Philips Zoom</span>
        <span class="dental-comparison__price">$110/unit</span>
      </div>
    </div>
  </div>
</section>

<style>
  .dental-comparison__price-item--origin {
    background: var(--dental-announcement-gradient, linear-gradient(135deg, #7C3AED, #6D28D9));
    color: #fff;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .dental-comparison__price-item--origin .dental-comparison__price-label,
  .dental-comparison__price-item--origin .dental-comparison__price {
    color: #fff;
  }
  .dental-comparison__price-item--other {
    background: #F5F5FF;
    color: #6B7280;
    border-radius: 12px;
    padding: 16px;
    text-align: center;
  }
  .dental-comparison__price-item--other .dental-comparison__price-label,
  .dental-comparison__price-item--other .dental-comparison__price {
    color: #6B7280;
  }
</style>

{% schema %}
{
  "name": "Dental Comparison",
  "tag": "div",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "Product Compare"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Dental Origin Compares"
    }
  ],
  "presets": [
    {
      "name": "Dental Comparison"
    }
  ]
}
{% endschema %}
