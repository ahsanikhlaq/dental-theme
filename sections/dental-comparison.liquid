{{ 'dental-landing.css' | asset_url | stylesheet_tag }}

<section class="dental-comparison">
  <div class="dental-container">
    <div class="dental-section-header">
      <span class="dental-hero__badge">{{ section.settings.badge_text }}</span>
      <h2 class="dental-section-heading">{{ section.settings.heading }}</h2>
    </div>

    <table class="dental-comparison__table">
      <thead>
        <tr>
          <th>Feature</th>
          <th class="dental-comparison__highlight">Dental Origin</th>
          <th>Opalescence Go</th>
          <th>Kor Night</th>
          <th>Philips Zoom</th>
        </tr>
      </thead>
      <tbody>
        <tr>
          <td>Carbamide or Hydrogen Peroxide</td>
          <td class="dental-comparison__highlight">CP or HP</td>
          <td>HP</td>
          <td>CP</td>
          <td>CP</td>
        </tr>
        <tr>
          <td>Customizable Strength</td>
          <td class="dental-comparison__highlight">6-35%</td>
          <td>10% or 15%</td>
          <td>16% only</td>
          <td>10% or 22%</td>
        </tr>
        <tr>
          <td>One-size Fits All</td>
          <td class="dental-comparison__highlight">
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
          <td>
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
        </tr>
        <tr>
          <td>Sensitivity Relief</td>
          <td class="dental-comparison__highlight">
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
        </tr>
        <tr>
          <td>Fully Customizable</td>
          <td class="dental-comparison__highlight">
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
          <td>
            <svg class="dental-x-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#EF4444" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
          </td>
        </tr>
        <tr>
          <td>Private Labeling</td>
          <td class="dental-comparison__highlight">
            <svg class="dental-check-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#16A34A" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>
          </td>
