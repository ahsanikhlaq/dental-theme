          "label": "Perks (comma separated)"
        }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Does The Whitening Work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Yes, our professional-grade formula uses 35% Carbamide Peroxide for effective whitening results.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dental Pricing",
      "blocks": [
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "gallery_image" },
        { "type": "pricing_tier", "settings": { "name": "50/units - Trial Order", "unit_price": "$46.00/unit", "price": "$2,300.00", "original_price": "", "badge": "", "selected": false } },
        { "type": "pricing_tier", "settings": { "name": "100/units - Startups", "unit_price": "$34.00/unit", "price": "$3,400.00", "original_price": "$4,600.00", "badge": "Most Popular", "badge_style": "popular", "selected": true, "perks": "Money Back Guarantee, Free Shipping, Tax Included" } },
        { "type": "pricing_tier", "settings": { "name": "250/units - Established", "unit_price": "$29.00/unit", "price": "$7,250.00", "original_price": "$11,500.00", "badge": "BEST DEAL", "badge_style": "best", "selected": false } },
        { "type": "pricing_tier", "settings": { "name": "1000/units - DSOs", "unit_price": "$26.00/unit", "price": "$26,000.00", "original_price": "$46,000.00", "selected": false } },
