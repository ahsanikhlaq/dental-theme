      "label": "Product Title",
      "default": "Custom Teeth Whitening Kit - Pens"
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating Text",
      "default": "40K+ happy patients"
    },
    {
      "type": "text",
      "id": "note_text",
      "label": "Note Text",
      "default": "Easy Onboarding will begin after checkout."
    },
    {
      "type": "text",
      "id": "savings_text",
      "label": "Savings Headline",
      "default": "Save Up To 56% Today with DSO Pricing"
    },
    {
      "type": "text",
      "id": "order_btn_text",
      "label": "Order Button Text",
      "default": "start your order"
