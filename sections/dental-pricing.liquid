          "default": "$34.00/unit"
        },
        {
          "type": "text",
          "id": "price",
          "label": "Total Price",
          "default": "$3,400.00"
        },
        {
          "type": "text",
          "id": "original_price",
          "label": "Original Price (strikethrough)"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge Text"
        },
        {
          "type": "select",
          "id": "badge_style",
          "label": "Badge Style",
          "options": [
            { "value": "popular", "label": "Most Popular (Green)" },
            { "value": "best", "label": "Best Deal (Yellow)" }
