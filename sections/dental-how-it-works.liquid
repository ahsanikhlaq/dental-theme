{{ 'dental-landing.css' | asset_url | stylesheet_tag }}

<section class="dental-how-it-works" id="how-it-works">
  <div class="dental-how-it-works__inner">
    <div class="dental-how-it-works__content">

      <div class="dental-dashed-line">
        <img src="{{ 'dental-dashed-line.png' | asset_url }}" alt="" loading="lazy" aria-hidden="true">
      </div>

      <div class="dental-section-header dental-animate dental-fade-up">
        <span class="dental-hero__badge">{{ section.settings.badge_text }}</span>
        <h2 class="dental-section-heading">{{ section.settings.heading }}</h2>
      </div>

      <div class="dental-steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="dental-step dental-animate dental-fade-up" {{ block.shopify_attributes }} style="animation-delay: {{ forloop.index | times: 0.15 }}s;">
              <div class="dental-step__icon">
                <img src="{{ 'dental-step-icon-' | append: forloop.index | append: '.png' | asset_url }}" alt="{{ block.settings.label | escape }}" loading="lazy" width="64" height="64">
              </div>
              <p class="dental-step__label">{{ block.settings.label }}</p>
            </div>

            {%- unless forloop.last -%}
              <div class="dental-step__arrow">
                <svg width="40" height="16" viewBox="0 0 40 16" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M0 8H38" stroke="#4A4FE4" stroke-width="2" stroke-dasharray="4 4"/>
                  <path d="M32 1L39 8L32 15" stroke="#4A4FE4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
            {%- endunless -%}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="dental-how-it-works__image dental-animate dental-fade-up">
        {%- if section.settings.product_image != blank -%}
          <img
            src="{{ section.settings.product_image | image_url: width: 2400 }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="1200"
            height="495"
          >
        {%- else -%}
          <img
            src="{{ 'dental-how-it-works-product.png' | asset_url }}"
            alt="{{ section.settings.heading | escape }}"
            loading="lazy"
            width="1200"
            height="495"
          >
        {%- endif -%}
      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dental - How It Works",
  "tag": "section",
  "class": "dental-how-it-works-section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "SIMPLE PROCESS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How it Works?"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Step Label",
          "default": "Send us your logo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dental - How It Works",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "label": "Send us your logo"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "We design your kit"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "Unlimited Revisions"
          }
        },
        {
          "type": "step",
          "settings": {
            "label": "Shipped to your office"
          }
        }
      ]
    }
  ]
}
{% endschema %}
