{{ 'dental-landing.css' | asset_url | stylesheet_tag }}

<section class="dental-ingredients" id="ingredients">
  <div class="dental-container">
    <div class="dental-section-header dental-animate dental-fade-up">
      <span class="dental-hero__badge">{{ section.settings.badge_text }}</span>
      <h2 class="dental-section-heading">{{ section.settings.heading }}</h2>
    </div>

    <div class="dental-ingredients__values">
      {%- assign values = "FDA-Registered,Sensitivity-Managed,3rd-Party Tested,Professional-Strength Gel" | split: ',' -%}
      {%- for value in values -%}
        <span class="dental-ingredients__value-item">
          <span class="dental-ingredients__value-icon">
            <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          </span>
          {{ value }}
        </span>
      {%- endfor -%}
    </div>

    <div class="dental-ingredients__grid">
      <div class="dental-ingredients__product">
        <div class="dental-ingredients__product-circle">
          {%- if section.settings.product_image != blank -%}
            <img class="dental-ingredients__product-img" src="{{ section.settings.product_image | image_url: width: 1142 }}" alt="Product" width="571" height="570" loading="lazy">
          {%- else -%}
            <img class="dental-ingredients__product-img" src="{{ 'dental-pricing-main.png' | asset_url }}" alt="Product" width="571" height="570" loading="lazy">
          {%- endif -%}
        </div>
      </div>

      <div class="dental-ingredients__cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'ingredient' -%}
            <div class="dental-ingredient-card dental-animate dental-fade-up" {{ block.shopify_attributes }} style="animation-delay: {{ forloop.index | times: 0.15 }}s;">
              <span class="dental-ingredient-card__tag">{{ block.settings.tag }}</span>
              <h3 class="dental-ingredient-card__name">{{ block.settings.name }}</h3>
              <ul class="dental-ingredient-card__list">
                {%- assign bullets = block.settings.bullets | split: '|' -%}
                {%- for bullet in bullets -%}
                  <li>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none"><circle cx="12" cy="12" r="12" fill="#6C63FF" opacity="0.15"/><path d="M7.5 12.5l3 3 6-6" stroke="#6C63FF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    {{ bullet | strip }}
                  </li>
                {%- endfor -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Dental Ingredients",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "default": "INGREDIENTS"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Clinical-Grade Formula"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "ingredient",
      "name": "Ingredient",
      "settings": [
        {
          "type": "text",
          "id": "tag",
          "label": "Tag",
          "default": "Sensitivity Free"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Ingredient Name",
          "default": "35% Carbamide Peroxide"
        },
        {
          "type": "textarea",
          "id": "bullets",
          "label": "Bullet Points (separate with |)",
          "default": "Breaks down deep intrinsic stains|Gradual oxidation for reduced sensitivity|Designed for multi-session at-home protocols"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Dental Ingredients",
      "blocks": [
        { "type": "ingredient", "settings": { "tag": "Sensitivity Free", "name": "35% Carbamide Peroxide", "bullets": "Breaks down deep intrinsic stains|Gradual oxidation for reduced sensitivity|Designed for multi-session at-home protocols" } },
        { "type": "ingredient", "settings": { "tag": "Desensitizing Gel", "name": "3% Potassium Nitrate", "bullets": "Nerve desensitization|Enamel-safe formulation|Improves overall patient experience" } },
        { "type": "ingredient", "settings": { "tag": "Effective Whitening", "name": "12% Hydrogen Peroxide", "bullets": "Accelerated stain lifting|Ideal for shorter treatment cycles|Visible shade improvement" } },
        { "type": "ingredient", "settings": { "tag": "Accelerator", "name": "LED Mouth Piece", "bullets": "Keep the patients mouth dry|Built-in timer|Designed for at-home compliance" } }
      ]
    }
  ]
}
{% endschema %}
